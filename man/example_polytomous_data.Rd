\name{example_polytomous_data}
\alias{example_polytomous_data}
\title{Example data for polytomous threshold Wright maps}
\usage{
example_polytomous_data()
}
\value{
A list with person measures, item measures, shared step thresholds, category
codes, and category labels.
}
\description{
Returns a small polytomous example based on a three-category structure that can
be used to demonstrate half-point, Thurstonian, Andrich, and category-center
Wright maps.
}
\examples{
pdat <- example_polytomous_data()
str(pdat)
}
